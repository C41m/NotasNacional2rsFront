{
  "buildCommand": "npm run build -- --configuration=production",
  "outputDirectory": "dist/frontend/browser",
  "installCommand": "npm install",
  "framework": "angular",
  "env": {
    "API_URL": "/api"
  },
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "https://automacao-notas-nacional-2rs-api.onrender.com/$1"
    }
  ]
}