{
  "buildCommand": "npm run build -- --configuration=production",
  "outputDirectory": "dist/frontend/browser",
  "installCommand": "npm install",
  "framework": "angular",
  "env": {
    "API_URL": "https://automacao-notas-nacional-2rs-api.onrender.com"
  },
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://automacao-notas-nacional-2rs-api.onrender.com/api/:path*"
    }
  ]
}